    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-gh-corner": "^1.1.4",
    "react-github-calendar": "^3.3.1",
    "react-grid-system": "^8.1.3",
    "rehype-highlight": "^5.0.2",
